# IoT Summit Website - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ===== SMTP Email Configuration =====
# Email service configuration for form submissions
# Required for email notifications to work

# SMTP Host (e.g., smtp.gmail.com, mail.company.com)
SMTP_HOST=your-smtp-host.com

# SMTP Port (usually 587 for TLS or 465 for SSL)
SMTP_PORT=587

# Use TLS/SSL (true for port 465, false for port 587)
SMTP_SECURE=false

# SMTP Username/Email
SMTP_USER=your-email@company.com

# SMTP Password or App Password (for Gmail, use App Password)
SMTP_PASSWORD=your-app-password

# From email address (shown in email headers)
SMTP_FROM_EMAIL="IoT Summit <noreply@iotsummit.ae>"

# Contact email address (receives form submissions)
CONTACT_EMAIL=enquiry@confexmeet.com

# ===== Google Sheets Integration (Optional) =====
# Enable automatic lead storage to Google Sheets
# Set up Google Cloud project with Sheets API enabled

# Google Sheets API Key
GOOGLE_SHEETS_API_KEY=your-api-key

# Google Sheets Document ID (found in URL)
GOOGLE_SHEETS_ID=your-sheet-id

# ===== Site Configuration =====
# General site settings

# Base URL (used for email links, social sharing, etc.)
NEXT_PUBLIC_SITE_URL=https://iotsummit.ae

# Event dates
NEXT_PUBLIC_EVENT_START_DATE=2026-03-15
NEXT_PUBLIC_EVENT_END_DATE=2026-03-17

# Location
NEXT_PUBLIC_EVENT_LOCATION=Abu Dhabi International Convention Centre, 5C, 115, OMBR Layout, Bangalore-43

# ===== Analytics (Optional) =====
# Third-party analytics tracking

# Google Analytics ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics Token
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-token

# ===== Development Settings =====
# Node environment
NODE_ENV=production

# ===== Usage =====
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in all required values (marked with *)
# 3. Optional fields can be left empty if not using those features
# 4. Never commit .env.local to version control
# 5. Add .env.local to .gitignore

# ===== SMTP Provider Quick Guides =====

# GMAIL:
# 1. Enable 2-Factor Authentication
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. SMTP_HOST=smtp.gmail.com
# 4. SMTP_PORT=587
# 5. SMTP_SECURE=false
# 6. SMTP_USER=your-email@gmail.com
# 7. SMTP_PASSWORD=<generated-16-char-password>

# SENDGRID:
# 1. Create SendGrid account and API key
# 2. SMTP_HOST=smtp.sendgrid.net
# 3. SMTP_PORT=587
# 4. SMTP_SECURE=false
# 5. SMTP_USER=apikey
# 6. SMTP_PASSWORD=<your-sendgrid-api-key>

# AWS SES:
# 1. Verify sender email in AWS SES
# 2. SMTP_HOST=email-smtp.region.amazonaws.com
# 3. SMTP_PORT=587
# 4. SMTP_SECURE=false
# 5. SMTP_USER=<smtp-username>
# 6. SMTP_PASSWORD=<smtp-password>

# CUSTOM MAIL SERVER:
# Contact your IT department for SMTP credentials
# Typically provided as a relay service for your domain
